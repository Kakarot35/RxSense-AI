# OpenAI API Key - Get yours at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# App Environment (development, production)
ENVIRONMENT=development
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rxexplainer

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Storage
CHROMA_PERSIST_DIR=./chroma_db

# Logging
LOG_LEVEL=INFO

# External APIs (Optional)
DRUGBANK_API_KEY=your_drugbank_api_key_here
GOOGLE_TTS_KEY=your_google_tts_key_here
HF_HOME=D:/Data Analysts/Medical/.hf_cache
